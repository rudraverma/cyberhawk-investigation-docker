# ── CyberHawk Docker — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values before running docker compose up -d
# NEVER commit .env to git

# ── Optional: Anthropic API key ───────────────────────────────────────────────
# Only needed if you want the embedded chat widget in the UI.
# Leave blank to use Claude Code via MCP (recommended — no API cost).
ANTHROPIC_API_KEY=

# ── Optional: External enrichment APIs ───────────────────────────────────────
# Used by skills that call external reputation services.
# Leave blank to skip enrichment steps.
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# ── Investigation service endpoints (set to your host/service addresses) ──────
# The pipeline reaches these; defaults are docker service names. If a service
# runs on the host network, set the full URL with your server IP here instead.
DEOBFUSCATOR_URL=http://cyberhawk-deobfuscator:3020/deobfuscate
MITM_PROXY=http://ch-ether-proxy:8095
ETHERHAWK_WEBHOOK_URL=http://ch-ether-api:8094/webhook/etherhiding-confirmed

# ── EtherHawk webhook shared secret (CHANGE THIS to a random value) ───────────
ETHERHAWK_WEBHOOK_SECRET=change-me-to-a-random-secret

# ── UI: MITM live-view iframe URL (build-time, Vite) ──────────────────────────
VITE_MITM_URL=
